def bullet(c, x, y, text, color=C_TEAL, size=10):
    c.setFillColor(color)
    c.circle(x, y+3, 4, fill=1, stroke=0)
    c.setFillColor(C_WHITE)
    c.setFont("Helvetica", size)
    c.drawString(x+10, y, text)
    return y

def wrap_text(c, text, x, y, max_w, font="Helvetica", size=9, color=C_LGRAY, line_h=13):
    c.setFillColor(color)
    c.setFont(font, size)
    words = text.split()
    line = ""
    for w in words:
        test = line + w + " "
        if c.stringWidth(test, font, size) > max_w:
            c.drawString(x, y, line.strip())
            y -= line_h
            line = w + " "
        else:
            line = test
    if line:
        c.drawString(x, y, line.strip())
        y -= line_h
    return y

def box(c, x, y, w, h, fill=C_CARD, stroke=C_TEAL, sw=1, r=6):
    c.setFillColor(fill)
    c.setStrokeColor(stroke)
    c.setLineWidth(sw)
    c.roundRect(x, y, w, h, r, fill=1, stroke=1)

def label_box(c, cx, cy, bw, bh, text, fill=C_CARD, text_color=C_WHITE,
              font="Helvetica-Bold", fsize=9, stroke=C_TEAL, sw=1, r=5):
    box(c, cx-bw/2, cy-bh/2, bw, bh, fill=fill, stroke=stroke, sw=sw, r=r)
    c.setFillColor(text_color)
    c.setFont(font, fsize)
    lines = text.split("\n")
    lh = fsize + 2
    start_y = cy + (len(lines)-1)*lh/2
    for l in lines:
        c.drawCentredString(cx, start_y, l)
        start_y -= lh

def arrow_h(c, x1, y, x2, color=C_TEAL, lw=1.5):
    c.setStrokeColor(color)
    c.setFillColor(color)
    c.setLineWidth(lw)
    c.line(x1, y, x2-6, y)
    # arrowhead
    p = c.beginPath()
    p.moveTo(x2, y)
    p.lineTo(x2-7, y+4)
    p.lineTo(x2-7, y-4)
    p.close()
    c.drawPath(p, fill=1, stroke=0)

def arrow_v(c, x, y1, y2, color=C_TEAL, lw=1.5):
    c.setStrokeColor(color)
    c.setFillColor(color)
    c.setLineWidth(lw)
    c.line(x, y1, x, y2+6)
    p = c.beginPath()
    p.moveTo(x, y2)
    p.lineTo(x-4, y2+7)
    p.lineTo(x+4, y2+7)
    p.close()
    c.drawPath(p, fill=1, stroke=0)

def section_tag(c, x, y, text, color=C_TEAL):
    tw = c.stringWidth(text, "Helvetica-Bold", 8) + 16
    c.setFillColor(color)
    c.roundRect(x, y, tw, 16, 4, fill=1, stroke=0)
    c.setFillColor(C_BG)
    c.setFont("Helvetica-Bold", 8)
    c.drawString(x+8, y+5, text)

