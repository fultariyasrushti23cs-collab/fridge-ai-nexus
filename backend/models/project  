def slide_system_diagram(c):
    bg(c); slide_header(c, 4, "System Architecture Diagram", "Data flow across all layers")

    # ─ Draw a horizontal pipeline diagram ─
    layers = [
        ("USER",        C_TEAL,   ["Web Browser","Mobile App"]),
        ("FRONTEND",    C_GREEN,  ["React.js","Next.js"]),
        ("BACKEND",     C_YELLOW, ["Node.js","FastAPI"]),
        ("AI ENGINE",   C_RED,    ["LLM Agent","Nutrition\nAnalysis"]),
        ("DATABASE",    C_PURPLE, ["MongoDB","AWS S3"]),
    ]

    n = len(layers)
    margin = 32
    bw = (W - 2*margin - (n-1)*20) / n
    bh = 200
    y0 = H - 100  # top of boxes
    node_h = 38

    for i, (lname, color, nodes) in enumerate(layers):
        bx = margin + i*(bw+20)
        by = y0 - bh

        # Outer column box
        c.setFillColor(C_PANEL)
        c.roundRect(bx, by, bw, bh, 8, fill=1, stroke=0)
        c.setStrokeColor(color)
        c.setLineWidth(1.2)
        c.roundRect(bx, by, bw, bh, 8, fill=0, stroke=1)

        # Layer header bar
        c.setFillColor(color)
        c.roundRect(bx, by+bh-24, bw, 24, 6, fill=1, stroke=0)
        c.rect(bx, by+bh-16, bw, 16, fill=1, stroke=0)  # square bottom corners
        c.setFillColor(C_BG)
        c.setFont("Helvetica-Bold", 8)
        c.drawCentredString(bx+bw/2, by+bh-15, lname)

        # Node boxes inside
        ny = by + bh - 42
        for node in nodes:
            nh = node_h
            c.setFillColor(C_CARD)
            c.roundRect(bx+6, ny-nh, bw-12, nh, 5, fill=1, stroke=0)
            c.setStrokeColor(color)
            c.setLineWidth(0.5)
            c.roundRect(bx+6, ny-nh, bw-12, nh, 5, fill=0, stroke=1)
            c.setFillColor(C_WHITE)
            c.setFont("Helvetica-Bold", 8)
            lines = node.split("\n")
            for j, ln in enumerate(lines):
                c.drawCentredString(bx+bw/2, ny-16-j*11, ln)
            ny -= nh + 8

        # Arrow to next layer
        if i < n-1:
            ax1 = bx + bw
            ax2 = bx + bw + 20
            ay = y0 - bh/2
            c.setStrokeColor(color)
            c.setLineWidth(2)
            c.line(ax1+1, ay, ax2-6, ay)
            c.setFillColor(color)
            p = c.beginPath()
            p.moveTo(ax2, ay)
            p.lineTo(ax2-7, ay+4)
            p.lineTo(ax2-7, ay-4)
            p.close()
            c.drawPath(p, fill=1, stroke=0)

    # Legend below
    legend_y = y0 - bh - 28
    c.setFillColor(C_LGRAY)
    c.setFont("Helvetica", 8)
    c.drawCentredString(W/2, legend_y,
        "Data flows left to right: User interaction → Frontend → Backend → AI Engine → Database Storage")

    # Bottom data flow labels
    labels = ["HTTP/HTTPS", "REST API", "gRPC / HTTP", "MongoDB Wire"]
    for i, lbl in enumerate(labels):
        lx = margin + (i+0.5)*(bw+20) + bw/2 + 4
        c.setFillColor(C_DGRAY)
        c.setFont("Helvetica", 7)
        c.drawCentredString(lx, legend_y - 16, lbl)

    footer(c, 4)


def slide_workflow(c):
    bg(c); slide_header(c, 5, "System Workflow Diagram", "End-to-end user journey")

    steps = [
        (C_TEAL,   "1",  "User\nRegisters"),
        (C_GREEN,  "2",  "Dashboard\nOpens"),
        (C_YELLOW, "3",  "Add Fridge\nItems"),
        (C_RED,    "4",  "AI Analyses\nInventory"),
        (C_PURPLE, "5",  "Meal Plans\nGenerated"),
        (C_TEAL,   "6",  "User Selects\nMeal"),
        (C_GREEN,  "7",  "Grocery\nList Created"),
        (C_YELLOW, "8",  "Nutrition\nTracked"),
        (C_RED,    "9",  "AI Report\nGenerated"),
        (C_PURPLE, "10", "Download /\nExport"),
    ]

    row1 = steps[:5]
    row2 = steps[5:][::-1]  # reversed to show snake path

    def draw_row(row, y_center, reverse=False):
        n = len(row)
        bw, bh = 88, 58
        gap = 18
        total = n*bw + (n-1)*gap
        x0 = (W - total)/2
        for i, (color, num, label) in enumerate(row):
            bx = x0 + i*(bw+gap)
            by = y_center - bh/2
            # Shadow
            c.setFillColor(c_hex("#050f18"))
            c.roundRect(bx+3, by-3, bw, bh, 8, fill=1, stroke=0)
            # Box
            c.setFillColor(C_CARD)
            c.roundRect(bx, by, bw, bh, 8, fill=1, stroke=0)
            c.setStrokeColor(color)
            c.setLineWidth(1.5)
            c.roundRect(bx, by, bw, bh, 8, fill=0, stroke=1)
            # Number badge
            c.setFillColor(color)
            c.circle(bx+16, by+bh-12, 10, fill=1, stroke=0)
            c.setFillColor(C_BG)
            c.setFont("Helvetica-Bold", 9)
            c.drawCentredString(bx+16, by+bh-15, num)
            # Label
            c.setFillColor(C_WHITE)
            c.setFont("Helvetica-Bold", 8)
            for j, ln in enumerate(label.split("\n")):
                c.drawCentredString(bx+bw/2, by+bh-28-j*12, ln)
            # Arrow
            if i < n-1:
                ax1 = bx+bw+1
                ax2 = bx+bw+gap-1
                ay = y_center
                c.setStrokeColor(color)
                c.setLineWidth(2)
                c.line(ax1, ay, ax2-6, ay)
                c.setFillColor(color)
                p = c.beginPath()
                p.moveTo(ax2, ay)
                p.lineTo(ax2-7, ay+4)
                p.lineTo(ax2-7, ay-4)
                p.close()
                c.drawPath(p, fill=1, stroke=0)

    y1 = H - 148
    y2 = H - 278
    draw_row(row1, y1)
    # Connector arrow going down on the right
    rbw = 88
    rgap = 18
    n = 5
    total = n*rbw + (n-1)*rgap
    x0 = (W - total)/2
    rx_right = x0 + total
    # Down arrow on right side
    c.setStrokeColor(C_PURPLE)
    c.setLineWidth(2.5)
    c.line(rx_right - rbw, y1-29, rx_right - rbw, y2+29)
    # Arrowhead pointing down to row2
    c.setFillColor(C_PURPLE)
    p = c.beginPath()
    p.moveTo(rx_right - rbw, y2+28)
    p.lineTo(rx_right - rbw - 5, y2+38)
    p.lineTo(rx_right - rbw + 5, y2+38)
    p.close()
    c.drawPath(p, fill=1, stroke=0)

    draw_row(row2, y2)

    # Note at bottom
    c.setFillColor(C_DGRAY)
    c.setFont("Helvetica", 8)
    c.drawCentredString(W/2, y2-48,
        "Snake-path workflow: Row 1 (Steps 1-5) → Down → Row 2 (Steps 6-10, right to left)")
    footer(c, 5)


